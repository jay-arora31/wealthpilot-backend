# Supabase transaction-mode pooler — use this for the FastAPI runtime.
# Dashboard: Project → Settings → Database → Connection pooling → Transaction
# Note the username is "postgres.<PROJECT_REF>", not plain "postgres".
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Direct connection — use ONLY for Alembic migrations (supports advisory locks
# and prepared statements that the transaction pooler strips).
# ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LOGFIRE_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173

